# Copy this file to `.env` in the repo root (or `backend/.env` if you use start.bat from backend).
# Never commit `.env` (it is gitignored).
#
# No spaces around = . Restart the API after saving (npm run dev or python backend/app.py).
# If the UI still says the key is missing, remove any empty OPENAI_API_KEY from Windows
# "Environment variables" (User/System) — it can block .env unless the app uses override (this app does).

OPENAI_API_KEY=
